  "main": "index.js",
  "scripts": {
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "npm run build --prefix client",
    "start:server": "npm start --prefix server",
    "start:client": "npm start --prefix client",
    "start": "npm run build:client && concurrently --kill-others-on-fail \"npm run start:server\" \"npm run start:client\""
  },
  "repository": {
    "type": "git",
    "url": "https://gitea.kood.tech/mihkeltruup/info-screens.git"
  },
